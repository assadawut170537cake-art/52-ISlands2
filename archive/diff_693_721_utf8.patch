+        }
+      }
+    }
+
+    return { count: successCount, errors: errors, accom: replyAccom, processedNames: processedNames, spreadsheet: ss };
+
+  } catch (globalError) {
+    console.error("เกิดข้อผิดพลาดร้ายแรงในฟังก์ชัน writeToDailySheet: " + globalError.stack);
