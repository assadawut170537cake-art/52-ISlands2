async function finalizeClockInSaving(dataToProcess, userId, token, checkStatus, customOtInput, targetFileId) {
    if (!targetFileId) targetFileId = getTargetFileIdByDate(dataToProcess.date);

    if (!targetFileId) {
        reply(token, "❌ ไม่พบลิงก์ไฟล์สำหรับเดือนนี้ (กรุณาเช็คการตั้งค่า)");
        return;
    }

    const writeRes = writeToDailySheet(dataToProcess, userId, targetFileId);
    let customOtSite = null; let customOtTask = null;

    if (customOtInput && writeRes.count > 0) {
        let parts = customOtInput.split('/');
        customOtSite = parts[0] ? parts[0].trim() : dataToProcess.default_site;
        customOtTask = parts[1] ? parts[1].trim() : "ทำ OT";

        const ss = SpreadsheetApp.openById(targetFileId);
        const sheet = ss.getSheetByName(parseThaiDate(dataToProcess.date));        
        if (sheet) {
            const dbData = sheet.getRange(GLOBAL_CONFIG.START_ROW, 4, sheet.getLastRow(), 2).getValues();
            dataToProcess.employees.forEach(emp => {
                const inputName = normalize(emp.firstname); 
                for(let i = 0; i < dbData.length; i++) {
                    if (normalize(dbData[i][0]) === inputName) {
                        const targetRow = i + GLOBAL_CONFIG.START_ROW;
                        sheet.getRange(targetRow, 9).setValue(customOtSite);
                        sheet.getRange(targetRow, 10).setValue(customOtTask);
                        break; 
                    }
                }
            });
        }
    }

    let txt = "";
    if (checkStatus && checkStatus.status === "WARNING") txt += `⚠️ แจ้งเตือน: ${checkStatus.msg}\n`;
    
    if (writeRes && writeRes.errors && writeRes.errors.length > 0) {
        txt += `⚠️ ตรวจไม่พบรายชื่อต่อไปนี้ในระบบ:\n- ${writeRes.errors.join('\n- ')}\n`;
    }
    
    const statusText = (!writeRes || writeRes.count === 0) ? "❌ ไม่พบข้อมูลที่บันทึกได้" : `✅ บันทึกสำเร็จ ${writeRes.count} คน`;

    // 🚨 [ระบบใหม่] ถ้าระบบแจ้งเตือนว่ามี Error (หาชื่อไม่เจอ) ให้แอบไปจดลงหน้า Error_Log
    if (txt !== "" || writeRes.count === 0) {
        let errorDetails = txt;
        if (writeRes.count === 0) errorDetails = "❌ ไม่พบข้อมูลที่บันทึกได้\n" + txt;
        logErrorToSheet(targetFileId, dataToProcess.original_msg || "ไม่ได้ระบุข้อความ", errorDetails.trim());
    }
    
    let timeStatus = "";
    if (!dataToProcess.time_end || dataToProcess.time_end === "") {
        timeStatus = `(ลงเวลาเข้า: ${dataToProcess.time_start})`; 
    } else {
        const toMins = (t) => {
            if (!t) return 0;
            const parts = t.toString().replace('.', ':').split(':');
            return (parseInt(parts[0]) || 0) * 60 + (parseInt(parts[1]) || 0);
        };
        
        const sMins = toMins(dataToProcess.time_start);
        let eMins = toMins(dataToProcess.time_end);
        if (eMins < sMins) eMins += 24 * 60; 
        
        let otMins = 0; let normMins = 0;
        if (sMins < 480) otMins += (Math.min(eMins, 480) - sMins);
        
        const nIn = Math.max(sMins, 480); const nOut = Math.min(eMins, 1020);
        normMins = Math.max(0, nOut - nIn);
        if (nIn <= 720 && nOut >= 780) normMins -= 60; 
        if (eMins > 1020) otMins += (eMins - Math.max(sMins, 1020));
        
        let hasNoonOt = false; let noonOtMins = 0;
        dataToProcess.employees.forEach(emp => {
            if (emp.has_ot_noon) {
                hasNoonOt = true;
                let mIn = toMins(emp.ot_noon_in || "12.00");
                let mOut = toMins(emp.ot_noon_out || "13.00");
                noonOtMins = Math.max(noonOtMins, mOut - mIn);
            }
        });
        if (hasNoonOt) otMins += noonOtMins;
        
        const normHr = parseFloat((normMins / 60).toFixed(2));
        const otHr = parseFloat((otMins / 60).toFixed(2));
        
        let otText = otHr > 0 ? ` | OT: ${otHr} ชม.` : "";
        timeStatus = `(เวลา: ${dataToProcess.time_start}-${dataToProcess.time_end} ➡️ ปกติ: ${normHr} ชม.${otText})`;
    }

    const warningFooter = "\n\n📌 โปรดตรวจเช็คความถูกต้อง หากผิดพลาดให้แจ้งแอดมินทันที";
    let finalTxt = txt.trim() ? `\n${txt.trim()}` : "";
    
    let displaySite = dataToProcess.default_site;
    if (customOtSite) displaySite += `\n[ไซต์ OT: ${customOtSite} | งาน OT: ${customOtTask}]`;

    const accomText = dataToProcess.default_Accom || (writeRes && writeRes.accom) || 'ไม่ได้ระบุ';
    const dateToShow = dataToProcess.date ? `\n📅 วันที่: ${dataToProcess.date}` : ""; 
    
    const finalMessage = `${statusText}${dateToShow}\n${timeStatus}\nไซต์: ${displaySite}\n[ที่พัก: ${accomText}]${finalTxt}${warningFooter}`;
    
    reply(token, finalMessage);
}

