//▶️ ส่วนที่ 8: ฟังก์ชันช่วยเหลือและจัดรูปแบบ
function normalize(text) {
  if (!text) return "";
  return text.toString().replace(/^(นาย|นาง|น\.?ส\.?|ด\.?ช\.?|ด\.?ญ\.?)/g, "").replace(/[.\s]/g, "").trim();
}

function parseThaiDate(s) {
  if (!s) return "";
  const p = s.split('/');
  if (p.length < 3) return s;
  
  const monthList = ["มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน", "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"];
  
  let d = parseInt(p[0]); let m = parseInt(p[1]); let y = parseInt(p[2]);
  if (isNaN(d) || isNaN(m) || isNaN(y)) return s;
  
  let fullYear = (y < 100) ? 2500 + y : (y < 2500 ? y + 543 : y);
  const monthName = monthList[m - 1]; 
  return `${d} ${monthName} ${fullYear}`;
}

function formatDateToShort(dateObj) {
  if (!(dateObj instanceof Date)) {
    const parts = String(dateObj).split(' ');
    if (parts.length < 3) return dateObj;
    const monthList = ["มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน", "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"];
    const d = parts[0];
    const m = (monthList.indexOf(parts[1]) + 1).toString().padStart(2, '0');
    const y = parts[2].slice(-2);
    return `${parseInt(d)}/${parseInt(m)}/${y}`;
  }
  
  const d = dateObj.getDate();
  const m = dateObj.getMonth() + 1;
  const y = dateObj.getFullYear().toString().slice(-2);
  return `${d}/${m}/${y}`;
}

function parseThaiDateToObject(dateStr) {
  const p = dateStr.split('/');
  if (p.length < 3) return new Date();
  const y = (parseInt(p[2]) < 100) ? (2000 + parseInt(p[2]) - 43) : (parseInt(p[2]) - 543);
  return new Date(y, parseInt(p[1]) - 1, parseInt(p[0]));
}

function checkDate(str) {
  if (!str) return { status: "OK" };
  const p = str.split('/'); 
  let y = parseInt(p[2]); if (y < 100) y += 2000;
  if (y > 2300) y -= 543; 
  const d = new Date(y, parseInt(p[1])-1, parseInt(p[0]));
  const today = new Date(); d.setHours(0,0,0,0);
  today.setHours(0,0,0,0);
  const diff = (today - d) / 86400000;
  
  if (diff <= 0) return { status: "OK" };
  if (diff <= 2) return { status: "WARNING", msg: "ส่งย้อนหลัง" };
  return { status: "BLOCK", msg: `ช้า ${Math.floor(diff)} วัน (ห้ามเกิน 2 วัน)` };
}

function formatDateThai(dateObj) {
  const d = dateObj.getDate();
  const m = GLOBAL_CONFIG.MONTH_LIST[dateObj.getMonth()];
  const y = dateObj.getFullYear() + 543;
