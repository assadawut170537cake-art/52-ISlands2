function logErrorToSheet(fileId, originalMsg, errorMsg) {
  if (!fileId) return;
  try {
    const ss = SpreadsheetApp.openById(fileId);
    let logSheet = ss.getSheetByName("Error_Log");

    // สร้างหน้าชีต Error_Log ใหม่ หากยังไม่มีในไฟล์เดือนนั้นๆ
    if (!logSheet) {
      logSheet = ss.insertSheet("Error_Log");
      logSheet.appendRow(["วัน-เวลาที่แจ้ง", "ข้อความจากไลน์ (ต้นฉบับ)", "สาเหตุที่แจ้งเตือน", "สถานะการตรวจสอบ"]);
      logSheet.getRange("A1:D1").setFontWeight("bold").setBackground("#FFD966").setHorizontalAlignment("center");
      logSheet.setColumnWidth(1, 150); // เวลา
      logSheet.setColumnWidth(2, 350); // ข้อความต้นฉบับ
      logSheet.setColumnWidth(3, 300); // สาเหตุ
      logSheet.setColumnWidth(4, 150); // สถานะ
      logSheet.setFrozenRows(1);
    }

    const timestamp = Utilities.formatDate(new Date(), "GMT+7", "dd/MM/yyyy HH:mm:ss");
    logSheet.appendRow([timestamp, originalMsg, errorMsg, "รอตรวจสอบ ❌"]);

    // จัดรูปแบบแถวใหม่ให้สวยงาม และใส่ Dropdown
    const lastRow = logSheet.getLastRow();
    logSheet.getRange(lastRow, 1, 1, 4).setVerticalAlignment("top");
    logSheet.getRange(lastRow, 2, 1, 2).setWrap(true); 

    const rule = SpreadsheetApp.newDataValidation().requireValueInList(["รอตรวจสอบ ❌", "แก้ไขแล้ว ✅"], true).build();
    logSheet.getRange(lastRow, 4).setDataValidation(rule).setHorizontalAlignment("center");

  } catch (e) {
    console.error("Log Error Failed: " + e.message);
  }
}

