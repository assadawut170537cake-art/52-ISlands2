async function doPost(e) {
  try {
    if (!e || !e.postData) return ContentService.createTextOutput("No Data");
    
    const json = JSON.parse(e.postData.contents);
    const event = json.events[0]; 
    if (!event) return ContentService.createTextOutput("OK");
    
    const { replyToken, source, message } = event; 
    const userId = source.userId;
    const props = PropertiesService.getScriptProperties();
    const status = props.getProperty("SYSTEM_STATUS") || "ON"; 

    if (message.type === "text") {
      const msg = message.text.trim(); 

      // 🛡️ ป้องกันการแอบส่งงานส่วนตัว
      if (source.type === "user" && userId !== GLOBAL_CONFIG.ADMIN_LINE_ID) {
          const warningMsg = "⚠️ ขออภัยครับ บอทรับลงรายงานเฉพาะใน 'ไลน์กลุ่ม' เท่านั้นครับ\n\n" +
                             "กรุณาส่งรายงานเข้าไปในกลุ่มงาน เพื่อความโปร่งใสและให้ทีมรับทราบข้อมูลร่วมกันครับ 🙏";
          reply(replyToken, warningMsg);

          const adminNotifyMsg = `🚨 พนักงานแอบทักส่วนตัว!\n👤 User ID: ${userId}\n💬 พยายามพิมพ์: ${msg}`;
          try {
            push(GLOBAL_CONFIG.ADMIN_LINE_ID, adminNotifyMsg);
          } catch(e) { console.error("Notify Error: " + e.message); }
          
          return ContentService.createTextOutput("OK"); 
      }

      // ⚡ ฟีเจอร์: ดักจับคำตอบ กรณีที่รอคอนเฟิร์ม (Stateful Conversation)
      const cache = CacheService.getScriptCache();
      let pendingClockIn12 = cache.get(`PENDING_CLOCKIN_${userId}`);
      let pendingOTConfirm = cache.get(`PENDING_OT_CONFIRM_${userId}`);
      let pendingOTDetails = cache.get(`PENDING_OT_DETAILS_${userId}`);

      if (pendingClockIn12 === "CLEARED") pendingClockIn12 = null;
      if (pendingOTConfirm === "CLEARED") pendingOTConfirm = null;
      if (pendingOTDetails === "CLEARED") pendingOTDetails = null;

      if (msg.startsWith("#") && (pendingClockIn12 || pendingOTConfirm || pendingOTDetails)) {
          cache.put(`PENDING_CLOCKIN_${userId}`, "CLEARED", 1);
          cache.put(`PENDING_OT_CONFIRM_${userId}`, "CLEARED", 1);
          cache.put(`PENDING_OT_DETAILS_${userId}`, "CLEARED", 1);
          pendingClockIn12 = null; pendingOTConfirm = null; pendingOTDetails = null;
      }

      if (pendingOTDetails) {
          if (msg === "ยกเลิกลงเวลา") {
              cache.put(`PENDING_OT_DETAILS_${userId}`, "CLEARED", 1);
              reply(replyToken, "❌ ยกเลิกการบันทึกเวลาเรียบร้อยแล้วครับ");
              return ContentService.createTextOutput("OK");
          }
          let dataToProcess = JSON.parse(pendingOTDetails);
          cache.put(`PENDING_OT_DETAILS_${userId}`, "CLEARED", 1);
          await finalizeClockInSaving(dataToProcess, userId, replyToken, dataToProcess.checkStatus, msg);
          return ContentService.createTextOutput("OK");
      }

      if (pendingOTConfirm) {
          let dataToProcess = JSON.parse(pendingOTConfirm);
          if (msg === "ทำที่เดิม/งานเดิม") {
              cache.put(`PENDING_OT_CONFIRM_${userId}`, "CLEARED", 1);
              await finalizeClockInSaving(dataToProcess, userId, replyToken, dataToProcess.checkStatus, null);
              return ContentService.createTextOutput("OK");
          } else if (msg === "เปลี่ยนไซต์/เปลี่ยนงาน") {
              cache.put(`PENDING_OT_CONFIRM_${userId}`, "CLEARED", 1);
              cache.put(`PENDING_OT_DETAILS_${userId}`, JSON.stringify(dataToProcess), 300);
              reply(replyToken, "กรุณาพิมพ์ ไซต์งาน และ งานที่ทำโอที ครับ\n(รูปแบบ: ไซต์งาน / รายละเอียดงาน)");
              return ContentService.createTextOutput("OK");
          } else if (msg === "ยกเลิกลงเวลา") {
              cache.put(`PENDING_OT_CONFIRM_${userId}`, "CLEARED", 1);
              reply(replyToken, "❌ ยกเลิกการบันทึกเวลาเรียบร้อยแล้วครับ");
              return ContentService.createTextOutput("OK");
          }
      }

      if (pendingClockIn12) {
          if (msg === "ยืนยันตามเวลาที่แจ้ง" || msg === "ลงเวลา 13.00 น.") {
              await processPendingClockIn(msg, pendingClockIn12, userId, replyToken);
              return ContentService.createTextOutput("OK");
          } else if (msg === "ยกเลิกลงเวลา") {
              cache.put(`PENDING_CLOCKIN_${userId}`, "CLEARED", 1); 
              reply(replyToken, "❌ ยกเลิกการบันทึกเวลาเรียบร้อยแล้วครับ");
              return ContentService.createTextOutput("OK");
          }
      }

      // 🚀 ประมวลผลคำสั่งหลัก (ต้องมี #)
      if (!msg.startsWith("#")) return ContentService.createTextOutput("Ignored");
      const content = msg.substring(1).trim(); 

      if (content === "เปิดระบบ") { 
        props.setProperty("SYSTEM_STATUS", "ON");
        reply(replyToken, "🟢 เปิดระบบแล้ว"); 
        return ContentService.createTextOutput("OK"); 
      }
      if (content === "ปิดระบบ") { 
        props.setProperty("SYSTEM_STATUS", "OFF");
        reply(replyToken, "🔴 ปิดระบบแล้ว"); 
        return ContentService.createTextOutput("OK"); 
      }
      if (status === "OFF") return ContentService.createTextOutput("Ignored"); 

      if (content === "ยกเลิกรายการล่าสุด" || content === "ยกเลิกล่าสุด") {
        await handleUndoLastAction(userId, replyToken);
        return ContentService.createTextOutput("OK");
      }
      if (content.startsWith("ยกเลิก") && content.length > 10) {
        const rawTextToUndo = content.replace("ยกเลิก", "").trim();
        await handleUndoFromText(rawTextToUndo, replyToken);
        return ContentService.createTextOutput("OK");
      }

      if (content.startsWith("เช็ครายงาน")) {
          await handleCheckReport(content, userId, replyToken);
      }
      else if (/^(คู่มือ|วิธีใช้|help|คำสั่ง)/i.test(content)) {
          showHelpCommand(replyToken);
      }
      else if (content === "ช่วยแก้ไข") {
          reply(replyToken, `🚨 @แอดมิน มีผู้ใช้งานต้องการความช่วยเหลือเรื่องรูปแบบการลงเวลาครับ`);
      }
      else if (/^(ลา|ขอลา|เช็ค|ดูยอด|ใครขาด|สรุปยอด|ประกาศ:|ลบ|สถานะระบบ)/.test(content)) {
          await handleCommands(content, replyToken, userId);
      }
      else if (/^\d{1,2}[\/.-]\d{1,2}/.test(content)) {
          await handleClockIn(content, userId, replyToken); 
      }
      else {
          reply(replyToken, "⚠️ รูปแบบไม่ถูกต้อง พิมพ์ #คู่มือ เพื่อดูตัวอย่างครับ");
      }

    } else if (message.type === "image") {
       await handleImageProcess(message.id, replyToken, userId);
    }
    
    return ContentService.createTextOutput("OK");
  } catch (err) {
    console.error(err);
    return ContentService.createTextOutput("Error");
  }
}

