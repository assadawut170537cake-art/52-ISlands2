function parseComplexMessage(text) {
  try {
    const cleanText = text.replace(/^#/, "").trim();
    const lines = cleanText.split('\n').map(l => l.trim()).filter(l => l);
    if (lines.length < 2) return null;

    const headerLine = lines[0]; 
    const headerMatch = headerLine.match(/^(\d{1,2}[\/.-]\d{1,2}[\/.-]\d{2,4})\s+(.+?)\s+เข้า\s+(.+)$/);
    if (!headerMatch) return null; 
    
    const dateStr = headerMatch[1];             
    let currentAccom = headerMatch[2].trim();   
    const defaultSite = headerMatch[3].trim();  

    let timeStart = "08.00"; let timeEnd = ""; let lineIndex = 1;       
    
    for (let i = 1; i < lines.length; i++) {
      let line = lines[i];
      line = line.replace(/[–—]/g, "-").replace(/\s*([-\u0E16\u0E36\u0E07])\s*/g, "-");

      const hasTimeFormat = /\d{1,2}[.:]\d{2}/.test(line); 
      const isListItem = /^\d+\./.test(line);              
      const hasDash = line.includes("-");

      if (hasTimeFormat && (!isListItem || hasDash)) {
         const timeMatch = line.match(/(\d{1,2}[.:]\d{2})(?:.*?(\d{1,2}[.:]\d{2}))?/);
         if (timeMatch) {
            timeStart = timeMatch[1].replace(':', '.'); 
            if (timeMatch[2]) timeEnd = timeMatch[2].replace(':', '.'); 
            else timeEnd = "";
         }
         lineIndex = i + 1; break; 
      }
    }

    let employees = []; 
    
    for (let i = lineIndex; i < lines.length; i++) {
      const line = lines[i];
      if (line.includes("***หมายเหตุ***")) break;
      if (line.startsWith("พักหน้างาน") || line.startsWith("พัก")) {
         const newAccom = line.replace(/พัก(หน้างาน)?/, "").trim(); 
         if (newAccom) currentAccom = newAccom; continue; 
      }

      if (/^\d+\./.test(line)) {
         const parts = line.split('/'); 
         if (parts.length < 2) continue; 

         let rawName = parts[0].replace(/^\d+\./, "").trim(); 
         let taskStr = parts[1].trim(); 
         
         let nameParts = rawName.split(/\s+/);
         const prefixes = ["นาย", "นาง", "น.ส.", "นส.", "ด.ช.", "ด.ญ."];
         let firstName = nameParts[0];
         let lastName = nameParts.length > 1 ? nameParts[nameParts.length-1] : ""; 
         
         prefixes.forEach(p => { if (firstName.startsWith(p)) firstName = firstName.replace(p, ""); });
         if (["นาย","นาง","น.ส.","นส."].includes(nameParts[0])) {
             firstName = nameParts[1];
             lastName = nameParts.length > 2 ? nameParts[2] : "";
         }

         let hasOtNoon = false; let otNoonIn = "12.00"; let otNoonOut = "13.00";
         const otRegex = /\(?\s*(OT|โอที)\s*เที่ยง\s*(?:(\d{1,2}[.:]\d{2})\s*[-ถึง]\s*(\d{1,2}[.:]\d{2}))?\s*\)?/i;
         const matchOT = taskStr.match(otRegex);

         if (matchOT) {
             hasOtNoon = true;
             if (matchOT[2] && matchOT[3]) {
                 otNoonIn = matchOT[2].replace(':', '.'); otNoonOut = matchOT[3].replace(':', '.');
             }
             taskStr = taskStr.replace(matchOT[0], "").replace(/^[\/\-\s]+|[\/\-\s]+$/g, "").trim();
             if (taskStr === "") taskStr = "ทำงาน"; 
         }

         employees.push({
           "firstname": firstName, "lastname": lastName, "task": taskStr,
           "accom": currentAccom, "has_ot_noon": hasOtNoon, "ot_noon_in": otNoonIn, "ot_noon_out": otNoonOut
         });
      }
    }

    if (employees.length === 0) return null;
    return { 
      "date": dateStr, "default_site": defaultSite, "default_Accom": currentAccom, 
      "time_start": timeStart, "time_end": timeEnd, "employees": employees 
    };
    
  } catch (e) { return null; }
}

function processSaveData(data, mode, token, userId) {
    if (!data.date || data.date === "TODAY") {
       const d = new Date();
       data.date = `${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()+543}`;
    }
    const check = checkDate(data.date);
    if (check.status === "BLOCK") { reply(token, `⛔ ${check.msg}`); return; }
    
    const targetFileId = getTargetFileIdByDate(data.date);
    const writeRes = writeToDailySheet(data, userId, targetFileId);
    let txt = check.status === "WARNING" ? `⚠️ ${check.msg}\n` : "";
    if (writeRes.errors.length > 0) txt += `⚠️ ${writeRes.errors.join('\n')}\n`;
    reply(token, `${writeRes.count === 0 ? "❌ ไม่พบข้อมูล" : `✅ บันทึก ${writeRes.count} คน`} (${data.default_site})\n[${mode === "AI_VISION" ? "📸" : "🤖"}]\n${txt}`);
}

//▶️ ส่วนที่ 4: ตรรกะลงเวลาและการทำงานหลัก (หัวใจ)
async function handleCommands(msg, token, userId) {
  const sys = `Analyze intent: LEAVE, UNDO, BROADCAST, HELP, CHECK_ID, ABSENT_CHECK, SYSTEM_STATUS, DELETE_ENTRY.
  JSON {intent, data}`;
  const raw = await callGemini(msg, sys, true);
  if (!raw) return;
  try {
    const res = JSON.parse(raw.replace(/```json|```/g, "").trim());
    const { intent, data } = res;
    let txt = "";
    
    switch (intent) {
      case "LEAVE": txt = recordLeaveData(data.name, data.type, data.date); break;
      case "UNDO": case "DELETE_ENTRY": txt = undoLastEntry(data.name, data.date); break;
      case "BROADCAST": txt = `📢 ประกาศ: ${data.message}`; break;
      case "HELP": txt = "📘 คู่มือ:\n- พิมพ์ 8/1/69 ไซต์ (8.00-17.00) \n1.ชื่อ/งาน\n- พิมพ์ 'ยกเลิกรายการล่าสุด'\n- พิมพ์ 'ยกเลิก' ตามด้วยข้อความเดิม\n- พิมพ์ 'ลา [ชื่อ] [ประเภท] [วันที่]'"; break;
      case "CHECK_ID": txt = `🆔 User ID ของคุณคือ: ${userId}`; break;
      case "SYSTEM_STATUS":
          const status = PropertiesService.getScriptProperties().getProperty("SYSTEM_STATUS") || "ON";
          txt = `⚙️ สถานะระบบ: ${status === "ON" ? "🟢 เปิดใช้งาน" : "🔴 ปิดใช้งาน"}`; break;
      case "ABSENT_CHECK": txt = handleCheckAbsent(data.date || "TODAY"); break;
      default: txt = "⚠️ ไม่เข้าใจคำสั่ง หรือรูปแบบผิด";
    }
    reply(token, txt);
  } catch (e) { reply(token, "❌ Cmd Error: " + e.message); }
}

async function handleClockIn(msg, userId, token) {
  const lock = LockService.getScriptLock();
  try { lock.waitLock(30000); } catch (e) {
    reply(token, "⚠️ ระบบกำลังประมวลผลข้อมูล กรุณาส่งซ้ำครับ"); return; 
  }
  try {
    let dataToProcess = parseComplexMessage(msg); 
    const textHasOtNoon = /(OT|โอที)\s*เที่ยง/i.test(msg); 
    const parsedHasOtNoon = dataToProcess && dataToProcess.employees && dataToProcess.employees.some(emp => emp.has_ot_noon);
    const isOtNoonMissed = textHasOtNoon && !parsedHasOtNoon;
    const isDataIncomplete = !dataToProcess || !dataToProcess.date || !dataToProcess.default_site || !dataToProcess.time_start || !dataToProcess.employees || dataToProcess.employees.length === 0 || isOtNoonMissed; 

    if (isDataIncomplete) {
       console.log("⚠️ Regex พลาด ส่งให้ AI ช่วยแกะ...");
       dataToProcess = await processMessageWithAI(msg);
    }
    
    // 🚨 หากบอทแกะข้อความไม่ได้เลย (พังยับเยิน) ให้จด Error Log แล้วตีกลับ
    if (!dataToProcess || !dataToProcess.date || !dataToProcess.employees || dataToProcess.employees.length === 0) {
       const fallbackId = getTargetFileIdByDate(null); // ดึงไฟล์เดือนปัจจุบัน
       logErrorToSheet(fallbackId, msg, "❌ ระบบไม่สามารถดึงข้อมูลได้ครบถ้วน (รูปแบบผิดปกติ หรือ พิมพ์ไม่ครบ)");
       reply(token, "❌ ระบบไม่สามารถดึงข้อมูลได้ครบถ้วน พิมพ์ #คู่มือ เพื่อดูตัวอย่างครับ");
       return; 
    }

    // 🌟 นำข้อความต้นฉบับแนบติดตัวแปรไป เพื่อเอาไปจด Log ในตอนท้าย
    dataToProcess.original_msg = msg;

    const targetFileId = getTargetFileIdByDate(dataToProcess.date);
    if (!targetFileId) { reply(token, "❌ ไม่พบลิงก์ไฟล์เดือนนี้"); return; }
    const check = checkDate(dataToProcess.date);
    if (check.status === "BLOCK") { reply(token, `⛔ บันทึกไม่ได้: ${check.msg}`); return; }

    const startTimeStr = dataToProcess.time_start.toString();
    const startHour = parseInt(startTimeStr.split('.')[0]); 
    if (startHour === 12) {
        dataToProcess.checkStatus = check; 
        const cache = CacheService.getScriptCache();
        cache.put(`PENDING_CLOCKIN_${userId}`, JSON.stringify(dataToProcess), 300);
        replyWithButtons(token, `ลงข้อมูลตามเวลาเข้า (${startTimeStr} น.) หรือ 13.00 น.?`, ["ยืนยันตามเวลาที่แจ้ง", "ลงเวลา 13.00 น.", "ยกเลิกลงเวลา"]);
        return; 
    }

    await checkOTAndProceed(dataToProcess, userId, token, check, targetFileId);
  } catch (e) { reply(token, "❌ Error: " + e.message);
  } finally { lock.releaseLock(); }
}

async function checkOTAndProceed(dataToProcess, userId, token, check, targetFileId) {
    const toMins = (t) => {
        if (!t) return 0;
        const parts = t.toString().replace('.', ':').split(':');
        return (parseInt(parts[0]) || 0) * 60 + (parseInt(parts[1]) || 0);
    };
    
    const sMins = toMins(dataToProcess.time_start);
    let eMins = toMins(dataToProcess.time_end);
    let hasOT = false;

    if (eMins > 0) {
        if (eMins < sMins) eMins += 24 * 60; // ทำข้ามคืน
        let otMins = 0;
        if (sMins < 480) otMins += (Math.min(eMins, 480) - sMins); // OT เช้า
        if (eMins > 1020) otMins += (eMins - Math.max(sMins, 1020)); // OT เย็น
        
        let hasNoonOt = false;
        let noonOtMins = 0;
        dataToProcess.employees.forEach(emp => {
            if (emp.has_ot_noon) {
                hasNoonOt = true;
                let nIn = toMins(emp.ot_noon_in || "12.00");
                let nOut = toMins(emp.ot_noon_out || "13.00");
                noonOtMins = Math.max(noonOtMins, nOut - nIn);
            }
        });
        if (hasNoonOt) otMins += noonOtMins;
        
        if (otMins > 0) hasOT = true;
    }

    if (hasOT) {
        dataToProcess.checkStatus = check; 
        const cache = CacheService.getScriptCache();
        cache.put(`PENDING_OT_CONFIRM_${userId}`, JSON.stringify(dataToProcess), 300);

        const questionText = `ตรวจพบว่ามีข้อมูลการทำ OT\n\nโปรดยืนยันว่า... ทำ OT ที่ไซต์งานเดิม และ ลักษณะงานเดิม หรือไม่?`;
        const buttons = ["ทำที่เดิม/งานเดิม", "เปลี่ยนไซต์/เปลี่ยนงาน", "ยกเลิกลงเวลา"];
        replyWithButtons(token, questionText, buttons);
    } else {
        await finalizeClockInSaving(dataToProcess, userId, token, check, null, targetFileId);
    }
}

