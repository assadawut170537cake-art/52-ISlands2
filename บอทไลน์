function writeToDailySheet(data, userId, fileId) {
  const ss = SpreadsheetApp.openById(fileId); 
  const sheetName = parseThaiDate(data.date);
  const sheet = ss.getSheetByName(sheetName);
  
  if (!sheet) return { count: 0, errors: ["ไม่พบหน้า Sheet: " + sheetName] };
  const lastRow = sheet.getLastRow();
  const startRow = GLOBAL_CONFIG.START_ROW; 
  if (lastRow < startRow) return { count: 0, errors: ["Sheet ว่างเปล่า"] };
  
  const dbData = sheet.getRange(startRow, 4, lastRow - startRow + 1, 16).getValues(); 

  let hasAnyName = false;
  for (let i = 0; i < dbData.length; i++) {
     if (dbData[i][0] && dbData[i][0].toString().trim() !== "") {
         hasAnyName = true; break;
     }
  }

  if (!hasAnyName) {
     return { count: 0, errors: [`หน้าชีต "${sheetName}" ยังไม่มีรายชื่อช่างเลยครับ! (กรุณาไปวางรายชื่อในคอลัมน์ D ของหน้านี้ก่อน)`] };
  }

  let successCount = 0; let errors = []; let processedNames = []; let replyAccom = "ไม่ได้ระบุ"; 

  data.employees.forEach(emp => {
    let rowIndex = -1; 
    const inputName = normalize(emp.firstname); 
    
    for (let i = 0; i < dbData.length; i++) {
      if (normalize(dbData[i][0]) === inputName && normalize(dbData[i][0]) !== "") {
          if (emp.lastname && normalize(emp.lastname) !== normalize(dbData[i][1])) continue;
          rowIndex = startRow + i; break; 
      }
    }
    if (rowIndex === -2) return; 
    if (rowIndex !== -1) { 
      sheet.getRange(rowIndex, GLOBAL_CONFIG.COL_SITE).setValue(data.default_site);
      sheet.getRange(rowIndex, GLOBAL_CONFIG.COL_WORK).setValue(emp.task);
      
      let empAccom = emp.accom;
      if (!empAccom || empAccom === "-" || empAccom === "เดิม") empAccom = sheet.getRange(rowIndex, GLOBAL_CONFIG.COL_ACCOM).getValue();
      else sheet.getRange(rowIndex, GLOBAL_CONFIG.COL_ACCOM).setValue(empAccom);

      if (successCount === 0) replyAccom = empAccom || "ไม่ได้ระบุ";

      const otHrs = calculateAndTimeEntry(sheet, rowIndex, data.time_start, data.time_end, emp.has_ot_noon, emp.ot_noon_in, emp.ot_noon_out);
      
      if (otHrs > 0) {
         sheet.getRange(rowIndex, 9).setValue(data.default_site); 
         sheet.getRange(rowIndex, 10).setValue(emp.task);        
      } else {
         sheet.getRange(rowIndex, 9).clearContent();
         sheet.getRange(rowIndex, 10).clearContent();
      }
      successCount++; processedNames.push(inputName);
    } else { errors.push(emp.firstname); }
  });

  if (userId && successCount > 0) {
      PropertiesService.getScriptProperties().setProperty(`LAST_ENTRY_${userId}`, JSON.stringify({ date: data.date, names: processedNames }));
  }
  return { count: successCount, errors: errors, accom: replyAccom };
}

function calculateAndTimeEntry(sheet, row, startTimeStr, endTimeStr, hasOtNoon, otNoonIn, otNoonOut) {
  if (!endTimeStr || endTimeStr.toString().trim() === "") {
     sheet.getRange(row, GLOBAL_CONFIG.COL_NORMAL_HR).clearContent(); 
     sheet.getRange(row, GLOBAL_CONFIG.COL_OT_M_IN, 1, 7).clearContent();
     return 0;
  }

  const toMins = (t) => {
    if (!t) return 0;
    const p = t.toString().replace('.', ':').split(':');
    return (parseInt(p[0]) || 0) * 60 + (p[1] ? parseInt(p[1]) : 0);
  };
  const toFormat = (m) => {
     let h = Math.floor(m / 60); const min = m % 60;
     if (h >= 24) h -= 24; 
     return (h < 10 ? "0" + h : h) + "." + (min < 10 ? "0" + min : min);
  };
  const toHrs = (m) => parseFloat((m / 60).toFixed(2));

  const sMins = toMins(startTimeStr);
  let eMins = toMins(endTimeStr);
  if (sMins === 0 || eMins === 0) return 0;
  if (eMins < sMins) eMins += (24 * 60); 

  let otTot = 0; let otData = ["", "", "", "", "", "", ""]; let normHr = ""; 

  if (sMins < 480) {
    const d = Math.min(eMins, 480) - sMins;
    if (d > 0) { otData[0] = toFormat(sMins); otData[1] = toFormat(Math.min(eMins, 480)); otTot += d; }
  }

  const nIn = Math.max(sMins, 480); const nOut = Math.min(eMins, 1020);  
  let nDur = Math.max(0, nOut - nIn);
  if (nIn <= 720 && nOut >= 780) nDur -= 60; 
  if (nDur > 0) normHr = toHrs(nDur); 

  if (hasOtNoon) {
    otData[2] = otNoonIn || "12.00";  
    otData[3] = otNoonOut || "13.00"; 
    otTot += Math.max(0, toMins(otData[3]) - toMins(otData[2])); 
  }

  if (eMins > 1020) {
    const d = eMins - Math.max(sMins, 1020);
    if (d > 0) { otData[4] = toFormat(Math.max(sMins, 1020)); otData[5] = toFormat(eMins); otTot += d; }
  }

  if (otTot > 0) otData[6] = toHrs(otTot); 

  sheet.getRange(row, GLOBAL_CONFIG.COL_NORMAL_HR).setValue(normHr || "");
  sheet.getRange(row, GLOBAL_CONFIG.COL_OT_M_IN, 1, 7).setValues([otData]);
  return toHrs(otTot);
}

async function handleUndoLastAction(userId, token) {
