//▶️ ส่วนที่ 3: ระบบ AI และแกะข้อความ (สมอง)
async function callGemini(content, system, isJson) {
  const model = getSecret("MODEL_NAME") || GLOBAL_CONFIG.MODEL_NAME;
  const apiKey = getSecret("GEMINI_API_KEY") || GLOBAL_CONFIG.GEMINI_API_KEY;
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`;
  const payload = { 
    contents: [{ parts: [{ text: content }] }], 
    systemInstruction: { parts: [{ text: system }] }, 
    generationConfig: { responseMimeType: isJson ? "application/json" : "text/plain" } 
  };
  return fetchGemini(url, payload, isJson);
}

async function callGeminiVision(base64Str, system, mimeType) {
  const model = getSecret("MODEL_NAME") || GLOBAL_CONFIG.MODEL_NAME;
  const apiKey = getSecret("GEMINI_API_KEY") || GLOBAL_CONFIG.GEMINI_API_KEY;
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`;
  const payload = { 
    contents: [{ parts: [{ text: "Extract data based on system instructions."
    }, { inlineData: { mimeType: mimeType, data: base64Str } }] }], 
    systemInstruction: { parts: [{ text: system }] }, 
    generationConfig: { responseMimeType: "application/json" } 
  };
  return fetchGemini(url, payload, true);
}

function fetchGemini(url, payload, isJson) {
  try {
    const options = {
      method: "post", contentType: "application/json",
      payload: JSON.stringify(payload), muteHttpExceptions: true
    };
    const res = UrlFetchApp.fetch(url, options);
    const responseCode = res.getResponseCode();
    const responseBody = res.getContentText();
    if (responseCode !== 200) {
      console.error("Gemini API Error (" + responseCode + "): " + responseBody); return null;
    }
    const json = JSON.parse(responseBody);
    if (json.candidates && json.candidates[0].content) {
      let text = json.candidates[0].content.parts[0].text;
      if (isJson) {
        text = text.replace(/```json/g, "").replace(/```/g, "").trim();
        if (!text.startsWith("{") && !text.startsWith("[")) return null;
        return JSON.parse(text);
      }
      return text;
    }
    return null;
  } catch (e) { 
    console.error("FetchGemini Exception: " + e.message); return null;
  }
}

