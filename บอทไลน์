//▶️ ส่วนที่ 6: ระบบคำนวณเวลาและ OT
function calculateMorningOT(entryTime) {
  let standardStartTime = new Date(entryTime);
  standardStartTime.setHours(8, 0, 0, 0); 
  let result = { isMorningOT: false, otIn: "", otOut: "" };
  if (entryTime < standardStartTime) {
    result.isMorningOT = true;
    result.otIn = Utilities.formatDate(entryTime, Session.getScriptTimeZone(), "HH:mm");
    result.otOut = GLOBAL_CONFIG.OT_MORNING_LIMIT;
  }
  return result;
}

function processTimeEntry(e) {
  const sheet = e.source.getActiveSheet();
  const range = e.range;
  const timeValue = range.getValue();
  if (timeValue instanceof Date) {
    const calculation = calculateMorningOT(timeValue);
    if (calculation.isMorningOT) {
      sheet.getRange(range.getRow(), GLOBAL_CONFIG.COL_OT_M_IN).setValue(calculation.otIn);
      sheet.getRange(range.getRow(), GLOBAL_CONFIG.COL_OT_M_OUT).setValue(calculation.otOut);
    }
  }
}

function calculateRowOT(sheet, row) {
  const range = sheet.getRange(row, 9, 1, 6);
  const times = range.getValues()[0];
  let totalHours = 0;
  const getDuration = (start, end) => {
    if (!start || !end) return 0;
    if (start instanceof Date && end instanceof Date) {
      let diff = end.getTime() - start.getTime();
      if (diff < 0) diff += (24 * 60 * 60 * 1000);
      return diff / (1000 * 60 * 60);
    }
    if (typeof start === 'number' && typeof end === 'number') {
      return Math.max(0, end - start);
    }
    return 0;
  };
  totalHours += getDuration(times[0], times[1]);
  totalHours += getDuration(times[2], times[3]);
  totalHours += getDuration(times[4], times[5]);
  const finalOT = Math.round(totalHours * 100) / 100;
  sheet.getRange(row, 17).setValue(finalOT);
  return finalOT;
}

