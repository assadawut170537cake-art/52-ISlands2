/**
 * ฟังก์ชันจัดการคำสั่ง #เช็ครายงาน
 */
async function handleCheckReport(content, userId, replyToken) {
  try {
    const textStr = content.replace("เช็ครายงาน", "").trim();

    if (!textStr) {
      const askMsg = "❓ ต้องการเช็ครายงานอะไรครับ?\n\n👤 ของบุคคล: ใส่ชื่อ (เช่น #เช็ครายงาน อัษฎาวุธ)\n📅 ของวันที่: ใส่วันที่ (เช่น #เช็ครายงาน 9/03/69)\n🏗️ ของไซต์งาน: ใส่ชื่อไซต์ (เช่น #เช็ครายงาน สวนหลวง)\n\n💡 หรือพิมพ์ระบุเจาะจง:\n- ชื่อ/ไซต์ (อัษฎาวุธ/สวนหลวง)\n- ชื่อ/วันที่ (อัษฎาวุธ/9/03/69)\n- ไซต์/วันที่ (สวนหลวง/9/03/69)";
      reply(replyToken, askMsg); return;
    }

    const parts = textStr.split("/");
    const param1 = parts[0] ? parts[0].trim() : "";
    const param2 = parts[1] ? parts[1].trim() : "";
    const isParam2Date = /\d{1,2}[\/.-]\d{1,2}/.test(param2);
    const isParam1Date = /\d{1,2}[\/.-]\d{1,2}/.test(param1);

    let criteria = { name: null, site: null, date: null };

    if (parts.length === 1) {
      if (isParam1Date) { criteria.date = param1; } else { criteria.name = param1; } 
    } else {
      if (isParam2Date) { criteria.name = param1; criteria.date = param2; }
      else if (isParam1Date) { criteria.site = param2; criteria.date = param1; }
      else { criteria.name = param1; criteria.site = param2; }
    }

    const searchResult = queryReportData(criteria);

    if (!searchResult || searchResult.length === 0) {
      if (criteria.name && criteria.date) {
        const altMsg = `❌ ไม่พบรายงานของ "${criteria.name}" ในวันที่ ${criteria.date} ครับ\n\n🤔 ต้องการตรวจเช็ครายงานของวันที่ ${criteria.date} หรือไม่? ว่ามีใครส่งบ้าง\n(หากต้องการ ให้พิมพ์: #เช็ครายงาน ${criteria.date})`;
        reply(replyToken, altMsg);
      } else {
        reply(replyToken, `❌ ไม่พบข้อมูลตามที่ระบุ (${textStr}) ในไฟล์เดือนนี้ครับ`);
      }
      return;
    }

    let responseMsg = `📊 รายงานข้อมูล: ${textStr}\n`;
    if (parts.length === 1 && criteria.name) {
       const summary = searchResult[0]; 
       responseMsg = `👤 ชื่อ: ${summary.name}\n📈 สรุปยอดวิคนี้\n⏱️ วันทำงาน: ${summary.totalDays} วัน\n💰 OT รวม: ${summary.totalOT} ชม.`;
    } 
    else {
      searchResult.forEach((row, index) => { responseMsg += `\n${index + 1}. 📅 ${row.date}\n👤 ${row.name}\n🏗️ ไซต์: ${row.site}\n⏱️ ปกติ: ${row.normal} | OT: ${row.ot}\n---`; });
    }

    reply(replyToken, responseMsg);

  } catch (e) { reply(replyToken, "❌ HandleCheck Error: " + e.message); }
}

function getPayPeriodRange(dateStr) {
  const date = dateStr ? parseThaiDateToObject(dateStr) : new Date();
  const day = date.getDate();
  return {
    isFirstPeriod: day <= 15,
    periodText: day <= 15 ? "วิคที่ 1 (1-15)" : "วิคที่ 2 (16-สิ้นเดือน)"
  };
}

function queryReportData(criteria) {
  const dateStr = criteria.date || formatDateToShort(new Date());
  const targetFileId = getTargetFileIdByDate(dateStr);
  if (!targetFileId) return null;

  const ss = SpreadsheetApp.openById(targetFileId);
  const mParts = dateStr.split('/');
  const monthName = GLOBAL_CONFIG.MONTH_LIST[parseInt(mParts[1]) - 1];

  if (criteria.name && !criteria.site && !criteria.date) {
    const sheet = ss.getSheetByName("สรุป " + monthName);
    if (sheet) {
      const data = sheet.getDataRange().getValues();
      const day = parseInt(mParts[0]);
      let colIdx = (day <= 15) ? 4 + ((day - 1) * 2) : 45 + ((day - 16) * 2);

      for (let i = GLOBAL_CONFIG.START_ROW; i < data.length; i++) {
        const rowName = normalize(data[i][2] + (data[i][3] || "")); 
        if (rowName.includes(normalize(criteria.name))) {
          return { name: data[i][2] + " " + data[i][3], normal: data[i][colIdx] || 0, ot: data[i][colIdx + 1] || 0, type: "SUMMARY" };
        }
      }
    }
  }

  const sheet2 = ss.getSheetByName("1-31 " + monthName);
  if (sheet2) {
    const data2 = sheet2.getRange(4, 1, sheet2.getLastRow() - 3, 20).getValues();
    let results = [];
    data2.forEach(row => {
      const rowDateShort = formatDateToShort(row[0]); 
      const rowName = normalize(row[3] + (row[4] || "")); 
      const rowSite = normalize(row[5]); 

      let match = true;
      if (criteria.name && !rowName.includes(normalize(criteria.name))) match = false;
      if (criteria.site && !rowSite.includes(normalize(criteria.site))) match = false;
      if (criteria.date && rowDateShort !== criteria.date) match = false;

      if (match) {
        results.push({ date: rowDateShort, name: row[3] + " " + (row[4] || ""), site: row[5], normal: row[7], ot: row[16] });
      }
    });
    return results;
  }
  return null;
}