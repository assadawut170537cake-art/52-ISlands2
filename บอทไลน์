        const lastAction = JSON.parse(lastActionJson);
        const { date, names } = lastAction;
        
        const targetFileId = getTargetFileIdByDate(date);
        if (!targetFileId) { reply(token, "❌ ไม่พบไฟล์สำหรับเดือนนี้"); return; }
        
